# ===============================================
# Thought2Do — Environment Variable Template
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env`.
# ===============================================

# --- OpenAI (Whisper STT + GPT-4o-mini reasoning) ---
OPENAI_API_KEY=""

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://......
MONGODB_DB_NAME=thought2do

# --- JWT authentication ---
# Generate a strong value, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=23332545321
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- Pinecone (OPTIONAL — leave blank to disable vector features) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=thought2do-vault